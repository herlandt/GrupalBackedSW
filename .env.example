# Copiar a .env y completar. NUNCA subir el .env real al repositorio.

# --- App ---
APP_NAME=GrupalBackedSW
APP_ENV=development
DEBUG=true

# --- Base de datos: PostgreSQL local (recomendado) ---
# Usa tu PostgreSQL instalado. Crea una base 'tesisguard' y pon tu usuario/clave.
DATABASE_URL=postgresql+psycopg://postgres:TU_PASSWORD@localhost:5432/tesisguard
# Alternativa con Docker (docker-compose publica en 55432 para no colisionar):
# DATABASE_URL=postgresql+psycopg://tesisguard:tesisguard@localhost:55432/tesisguard
# Base de datos para los tests (se crea aparte):
TEST_DATABASE_URL=postgresql+psycopg://postgres:TU_PASSWORD@localhost:5432/tesisguard_test

# --- Seguridad / JWT ---
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# --- Secreto de endpoints internos (worker de colas -> POST /auditoria/internal/...) ---
# Se envía en la cabecera X-Internal-Token. En producción debe ser un valor propio.
INTERNAL_API_TOKEN=dev-internal-token-change-me

# --- Stripe (modo test) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx   # de: stripe listen --forward-to localhost:8000/api/v1/pagos/webhook

# --- AWS (usa el perfil de AWS CLI configurado en la máquina) ---
AWS_PROFILE=default
AWS_REGION=us-east-1
S3_DOCUMENTS_BUCKET=
S3_VIDEO_BUCKET=
SES_SENDER_EMAIL=

# --- CORS (lista de orígenes separada por comas) ---
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173

# --- Solo si usas la alternativa Docker (docker-compose) ---
POSTGRES_USER=tesisguard
POSTGRES_PASSWORD=tesisguard
POSTGRES_DB=tesisguard
PGADMIN_EMAIL=admin@tesisguard.local
PGADMIN_PASSWORD=admin
